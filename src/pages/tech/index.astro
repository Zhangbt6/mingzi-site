---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../utils/config";
import randomCover from "../../utils/randomCover";
import Footer from "../../components/Footer.astro";
import HeaderTitle from "../../components/partial/HeaderTitle.astro";
import HeaderSubTitle from "../../components/partial/HeaderSubTitle.astro";
import { formatDate } from "../../utils/formatDate";
import { urlFor } from "../../utils/urlFor";

type Props = {};

// Tech section aggregates projects + blog posts tagged with tech topics
const allProjects = await getCollection("projects", ({ data }) => !data.draft && data.tags?.some((t: string) => ["robotics", "ai", "control", "embedded", "llm", "cv"].includes(t)));
const allPosts = await getCollection("blog", ({ data }) => !data.draft && data.tags?.some((t: string) => ["tech", "robotics", "ai", "control", "embedded", "llm", "code"].includes(t)));

allProjects.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).getTime() : 0;
  const dateB = b.data.date ? new Date(b.data.date).getTime() : 0;
  return dateB - dateA;
});

allPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const techTags = ["robotics", "ai", "control", "embedded", "llm", "cv", "hardware"];
---

<BaseLayout>
  <HeaderTitle title="Tech" url={urlFor("/tech")} slot="header" />
  <HeaderSubTitle subtitle="机器人 · AI · 嵌入式 · 算法" url={urlFor("/tech")} slot="header" />

  <section id="main" aria-label="Main content">
    <div class="tech-header">
      <h1 class="page-title">Tech</h1>
      <p class="page-subtitle">机器人控制 · 人工智能 · 嵌入式系统 · 算法</p>
    </div>

    <!-- Tag Cloud -->
    <div class="tag-cloud">
      {techTags.map((tag) => (
        <span class="cloud-tag">#{tag}</span>
      ))}
    </div>

    <!-- Projects Section -->
    <div class="section">
      <h2 class="section-title">🚀 项目</h2>
      <div class="projects-grid">
        {
          allProjects.map((project) => (
            <a href={urlFor(`projects/${project.id}`)} class="project-card">
              <div class="project-cover">
                <img
                  src={urlFor(project.data.cover || randomCover())}
                  alt={project.data.title}
                  loading="lazy"
                />
              </div>
              <div class="project-info">
                <h3>{project.data.title}</h3>
                <p>{project.data.description}</p>
                <div class="tags">
                  {project.data.tags?.slice(0, 3).map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
            </a>
          ))
        }
        {
          allProjects.length === 0 && (
            <p class="empty-hint">暂无相关项目</p>
          )
        }
      </div>
    </div>

    <!-- Posts Section -->
    <div class="section">
      <h2 class="section-title">📝 笔记</h2>
      <div class="posts-list">
        {
          allPosts.map((post) => (
            <a href={urlFor(`blog/${post.id}`)} class="post-item">
              <div class="post-cover">
                <img
                  src={urlFor(post.data.cover || randomCover())}
                  alt={post.data.title}
                  loading="lazy"
                />
              </div>
              <div class="post-content">
                <h3>{post.data.title}</h3>
                <p>{post.data.excerpt || post.body?.slice(0, 120)}</p>
                <div class="post-meta">
                  <span>{formatDate(post.data.pubDate)}</span>
                  <div class="tags">
                    {post.data.tags?.slice(0, 3).map((tag: string) => (
                      <span class="tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </div>
            </a>
          ))
        }
        {
          allPosts.length === 0 && (
            <p class="empty-hint">暂无相关笔记</p>
          )
        }
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style lang="stylus">
  .tech-header {
    text-align: center;
    margin-bottom: 32px;
    padding: 32px;
    background: var(--color-wrap);
    border-radius: 12px;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-link);
    margin-bottom: 8px;
  }

  .page-subtitle {
    color: var(--grey-6);
    font-size: 1.1rem;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 40px;
    justify-content: center;
  }

  .cloud-tag {
    background: var(--color-wrap);
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.85rem;
    color: var(--grey-5);
    cursor: default;
    transition: 0.2s;

    &:hover {
      background: var(--red-1);
      color: white;
    }
  }

  .section {
    margin-bottom: 48px;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-link);
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--color-card);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }

  .project-card {
    background: var(--color-wrap);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: 0.3s;
    display: flex;
    flex-direction: column;

    &:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-card-hover);
    }
  }

  .project-cover {
    height: 140px;
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .project-info {
    padding: 16px;

    h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-link);
      margin: 0 0 8px;
    }

    p {
      font-size: 0.85rem;
      color: var(--grey-6);
      margin: 0 0 12px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    background: var(--color-card);
    padding: 3px 10px;
    border-radius: 10px;
    font-size: 0.75rem;
    color: var(--grey-5);
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .post-item {
    display: flex;
    gap: 16px;
    background: var(--color-wrap);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: 0.2s;
    padding: 16px;

    &:hover {
      transform: translateX(4px);
      box-shadow: var(--shadow-card);
    }
  }

  .post-cover {
    width: 120px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .post-content {
    flex: 1;
    min-width: 0;

    h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-link);
      margin: 0 0 6px;
    }

    p {
      font-size: 0.85rem;
      color: var(--grey-6);
      margin: 0 0 10px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  .post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--grey-5);
  }

  .empty-hint {
    color: var(--grey-6);
    font-size: 0.9rem;
    padding: 20px;
    text-align: center;
  }
</style>
