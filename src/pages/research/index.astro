---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";

import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../utils/config";
import randomCover from "../../utils/randomCover";
import Footer from "../../components/Footer.astro";
import HeaderTitle from "../../components/partial/HeaderTitle.astro";
import HeaderSubTitle from "../../components/partial/HeaderSubTitle.astro";
import { formatDate } from "../../utils/formatDate";
import { urlFor } from "../../utils/urlFor";

type Props = {};

const allResearch = await getCollection("research", ({ data }) => !data.draft);
allResearch.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const typeLabels: Record<string, string> = {
  paper: "📄 论文",
  patent: "📜 专利",
  opensource: "💻 开源",
  experiment: "🧪 实验",
  talk: "🎤 演讲",
  misc: "📦 其他",
};

const typeColors: Record<string, string> = {
  paper: "#60a5fa",
  patent: "#a78bfa",
  opensource: "#4ade80",
  experiment: "#fb923c",
  talk: "#f472b6",
  misc: "#94a3b8",
};
---

<BaseLayout>
  <HeaderTitle title="Research" url={urlFor("/research")} slot="header" />
  <HeaderSubTitle subtitle="科研成果 · 论文 · 专利 · 开源" url={urlFor("/research")} slot="header" />

  <section id="main" aria-label="Main content">
    <div class="research-header">
      <h1 class="page-title">Research</h1>
      <p class="page-subtitle">机器人控制 · 人工智能 · 嵌入式系统</p>
    </div>

    <div class="research-grid">
      {
        allResearch.map((item) => (
          <a href={urlFor(`research/${item.id}`)} class="research-card">
            <div class="card-cover">
              <img
                src={urlFor(item.data.cover || randomCover())}
                alt={item.data.title}
                loading="lazy"
              />
              <span
                class="type-badge"
                style={`background: ${typeColors[item.data.type] || "#94a3b8"}`}
              >
                {typeLabels[item.data.type] || item.data.type}
              </span>
            </div>
            <div class="card-info">
              <h3 class="card-title">{item.data.title}</h3>
              {item.data.venue && (
                <p class="card-venue">📍 {item.data.venue}</p>
              )}
              <p class="card-desc">
                {item.data.abstract || item.data.description || ""}
              </p>
              <div class="card-meta">
                <span class="card-date">{formatDate(item.data.date)}</span>
                <div class="card-tags">
                  {item.data.tags?.slice(0, 3).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
              <div class="card-links">
                {item.data.links?.pdf && (
                  <span class="link-icon" title="PDF">
                    <Icon name="fa6-solid:file-pdf" size={16} />
                  </span>
                )}
                {item.data.links?.repo && (
                  <span class="link-icon" title="代码">
                    <Icon name="fa6-brands:github" size={16} />
                  </span>
                )}
                {item.data.links?.demo && (
                  <span class="link-icon" title="演示">
                    <Icon name="fa6-solid:play" size={16} />
                  </span>
                )}
              </div>
            </div>
          </a>
        ))
      }
    </div>

    {
      allResearch.length === 0 && (
        <div class="empty-state">
          <Icon name="fa6-solid:flask" size={48} />
          <p>暂无科研成果</p>
        </div>
      )
    }
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style lang="stylus">
  .research-header {
    text-align: center;
    margin-bottom: 48px;
    padding: 32px;
    background: var(--color-wrap);
    border-radius: 12px;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-link);
    margin-bottom: 8px;
  }

  .page-subtitle {
    color: var(--grey-6);
    font-size: 1.1rem;
  }

  .research-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 24px;
  }

  .research-card {
    background: var(--color-wrap);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: 0.3s;
    display: flex;
    flex-direction: column;

    &:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-card-hover);
    }
  }

  .card-cover {
    height: 160px;
    overflow: hidden;
    position: relative;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: 0.3s;
    }
  }

  .research-card:hover .card-cover img {
    transform: scale(1.05);
  }

  .type-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    color: white;
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .card-info {
    padding: 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .card-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-link);
    margin: 0 0 8px;
    line-height: 1.4;
  }

  .card-venue {
    font-size: 0.85rem;
    color: var(--grey-5);
    margin: 0 0 12px;
  }

  .card-desc {
    font-size: 0.85rem;
    color: var(--grey-6);
    line-height: 1.6;
    margin: 0 0 16px;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }

  .card-date {
    font-size: 0.8rem;
    color: var(--grey-5);
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tag {
    background: var(--color-card);
    padding: 3px 8px;
    border-radius: 10px;
    font-size: 0.75rem;
    color: var(--grey-5);
  }

  .card-links {
    display: flex;
    gap: 12px;
    padding-top: 12px;
    border-top: 1px solid var(--color-card);
  }

  .link-icon {
    color: var(--grey-5);
    transition: 0.2s;
    cursor: pointer;

    &:hover {
      color: var(--red-1);
    }
  }

  .empty-state {
    text-align: center;
    padding: 80px;
    color: var(--grey-6);

    p {
      margin-top: 16px;
      font-size: 1.1rem;
    }
  }
</style>
