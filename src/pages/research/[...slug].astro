---
import { getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../utils/config";
import Footer from "../../components/Footer.astro";
import HeaderTitle from "../../components/partial/HeaderTitle.astro";
import { formatDate } from "../../utils/formatDate";
import { urlFor } from "../../utils/urlFor";

export async function getStaticPaths() {
  const entries = await getCollection("research");
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const typeLabels: Record<string, string> = {
  paper: "📄 论文",
  patent: "📜 专利",
  opensource: "💻 开源",
  experiment: "🧪 实验",
  talk: "🎤 演讲",
  misc: "📦 其他",
};
---

<BaseLayout>
  <HeaderTitle title={entry.data.title} url={urlFor(`/research/${entry.id}`)} slot="header" />

  <section id="main" aria-label="Main content">
    <!-- Hero -->
    <div class="research-hero">
      {entry.data.cover && (
        <div class="hero-cover">
          <img src={urlFor(entry.data.cover)} alt={entry.data.title} />
        </div>
      )}
      <div class="hero-info">
        <span class="type-badge">{typeLabels[entry.data.type] || entry.data.type}</span>
        <h1 class="hero-title">{entry.data.title}</h1>
        {entry.data.venue && (
          <p class="hero-venue">📍 {entry.data.venue}</p>
        )}
        <div class="hero-meta">
          <span>📅 {formatDate(entry.data.date)}</span>
          {entry.data.tags?.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Links -->
    {entry.data.links && (
      <div class="links-bar">
        {entry.data.links.pdf && (
          <a href={entry.data.links.pdf} class="link-btn" target="_blank">
            <Icon name="fa6-solid:file-pdf" size={16} /> PDF
          </a>
        )}
        {entry.data.links.doi && (
          <a href={`https://doi.org/${entry.data.links.doi}`} class="link-btn" target="_blank">
            <Icon name="fa6-solid:link" size={16} /> DOI
          </a>
        )}
        {entry.data.links.repo && (
          <a href={entry.data.links.repo} class="link-btn" target="_blank">
            <Icon name="fa6-brands:github" size={16} /> 代码
          </a>
        )}
        {entry.data.links.demo && (
          <a href={entry.data.links.demo} class="link-btn" target="_blank">
            <Icon name="fa6-solid:play" size={16} /> 演示
          </a>
        )}
        {entry.data.links.video && (
          <a href={entry.data.links.video} class="link-btn" target="_blank">
            <Icon name="fa6-solid:video" size={16} /> 视频
          </a>
        )}
      </div>
    )}

    <!-- Abstract -->
    {entry.data.abstract && (
      <div class="abstract-card">
        <h2>摘要</h2>
        <p>{entry.data.abstract}</p>
      </div>
    )}

    <!-- Content -->
    <div class="content-body">
      <Content />
    </div>

    <!-- Back -->
    <div class="back-link">
      <a href={urlFor("/research")}>← 返回 Research</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style lang="stylus">
  .research-hero {
    background: var(--color-wrap);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .hero-cover {
    height: 300px;
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .hero-info {
    padding: 32px;
  }

  .type-badge {
    display: inline-block;
    background: var(--red-1);
    color: white;
    padding: 4px 14px;
    border-radius: 14px;
    font-size: 0.85rem;
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-link);
    margin: 0 0 12px;
    line-height: 1.3;
  }

  .hero-venue {
    color: var(--grey-5);
    font-size: 1rem;
    margin: 0 0 16px;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    font-size: 0.9rem;
    color: var(--grey-5);
  }

  .tag {
    background: var(--color-card);
    padding: 4px 12px;
    border-radius: 12px;
    font-size: 0.8rem;
    color: var(--grey-5);
  }

  .links-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 24px;
  }

  .link-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    background: var(--color-wrap);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-link);
    font-size: 0.9rem;
    transition: 0.2s;

    &:hover {
      background: var(--red-1);
      color: white;
    }
  }

  .abstract-card {
    background: var(--color-wrap);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 24px;
    border-left: 4px solid var(--red-1);

    h2 {
      font-size: 1.2rem;
      color: var(--color-link);
      margin: 0 0 12px;
    }

    p {
      color: var(--grey-6);
      line-height: 1.8;
      margin: 0;
    }
  }

  .content-body {
    background: var(--color-wrap);
    border-radius: 12px;
    padding: 40px;
    margin-bottom: 24px;
  }

  .back-link {
    text-align: center;
    margin-top: 24px;

    a {
      color: var(--color-link);
      text-decoration: none;
      font-size: 0.95rem;
      transition: 0.2s;

      &:hover {
        color: var(--red-1);
      }
    }
  }
</style>
