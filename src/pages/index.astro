---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";

import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, BANNER } from "../utils/config";
import randomCover from "../utils/randomCover";
import { _p } from "../utils/i18n";
import { wordCount, readingTime } from "../utils/wordCount";
import Footer from "../components/Footer.astro";
import HeaderTitle from "../components/partial/HeaderTitle.astro";
import HeaderSubTitle from "../components/partial/HeaderSubTitle.astro";
import { formatDate } from "../utils/formatDate";
import { urlFor } from "../utils/urlFor";

type Props = {};

const allProjects = await getCollection("projects", ({ data }) => !data.draft);
const featuredProjects = allProjects.filter((p) => p.data.featured).slice(0, 3);
const recentPosts = await getCollection("blog", ({ data }) => !data.draft);
recentPosts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const latestPosts = recentPosts.slice(0, 5);
---

<BaseLayout>
  <!-- Header -->
  <HeaderTitle title={SITE.title} url={urlFor("/")} slot="header" />
  {
    SITE.subtitle && (
      <HeaderSubTitle subtitle={SITE.subtitle} url={urlFor("/")} slot="header" />
    )
  }

  <section id="main" aria-label="Main content">
    <!-- Hero Section -->
    <div class="hero-section">
      <div class="hero-content">
        <h1 class="hero-title">你好，我是<span class="highlight">明子</span></h1>
        <p class="hero-desc">
          研究机器人控制与人工智能，探索 LLM 与嵌入式系统的交叉领域。
          喜欢写代码、读论文、做有趣的项目。
        </p>
        <div class="hero-tags">
          <span class="tag">🤖 机器人控制</span>
          <span class="tag">🧠 人工智能</span>
          <span class="tag">💻 嵌入式</span>
          <span class="tag">📝 技术笔记</span>
        </div>
        <div class="hero-links">
          <a href="https://github.com" class="hero-link" target="_blank" rel="noopener">
            <Icon name="fa6-brands:github" size={20} />
            <span>GitHub</span>
          </a>
          <a href="mailto:mingzi@example.com" class="hero-link">
            <Icon name="fa6-solid:envelope" size={20} />
            <span>联系我</span>
          </a>
        </div>
      </div>
    </div>

    <!-- Featured Projects -->
    <div class="section">
      <div class="section-header">
        <h2 class="section-title">
          <Icon name="fa6-solid:rocket" size={24} />
          精选项目
        </h2>
        <a href={urlFor("/projects")} class="section-more">
          查看全部 →
        </a>
      </div>
      <div class="projects-grid">
        {
          featuredProjects.length > 0 ? (
            featuredProjects.map((project) => (
              <a href={urlFor(`projects/${project.id}`)} class="project-card">
                <div class="project-cover">
                  <img
                    src={urlFor(project.data.cover || randomCover())}
                    alt={project.data.title}
                    loading="lazy"
                  />
                </div>
                <div class="project-info">
                  <h3 class="project-title">{project.data.title}</h3>
                  <p class="project-desc">{project.data.description}</p>
                  <div class="project-tags">
                    {project.data.tags?.slice(0, 3).map((tag) => (
                      <span class="project-tag">{tag}</span>
                    ))}
                  </div>
                </div>
              </a>
            ))
          ) : (
            <div class="empty-state">
              <p>暂无精选项目</p>
              <a href={urlFor("/projects")} class="btn">浏览全部项目</a>
            </div>
          )
        }
      </div>
    </div>

    <!-- Recent Notes -->
    <div class="section">
      <div class="section-header">
        <h2 class="section-title">
          <Icon name="fa6-solid:book-open" size={24} />
          最新笔记
        </h2>
        <a href={urlFor("/notes")} class="section-more">
          查看全部 →
        </a>
      </div>
      <div class="notes-list">
        {
          latestPosts.length > 0 ? (
            latestPosts.map((post) => (
              <a href={urlFor(`blog/${post.id}`)} class="note-item">
                <span class="note-date">
                  {formatDate(post.data.pubDate)}
                </span>
                <span class="note-title">{post.data.title}</span>
                <span class="note-arrow">→</span>
              </a>
            ))
          ) : (
            <div class="empty-state">
              <p>暂无笔记</p>
            </div>
          )
        }
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style lang="stylus">
  .hero-section {
    background: var(--color-wrap);
    border-radius: 12px;
    padding: 48px;
    margin-bottom: 40px;
    text-align: center;
    position: relative;
    overflow: hidden;

    @media screen and (max-width: 767px) {
      padding: 32px 24px;
    }
  }

  .hero-title {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--color-link);

    @media screen and (max-width: 767px) {
      font-size: 1.8rem;
    }

    .highlight {
      background: linear-gradient(135deg, var(--red-1), var(--red-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--grey-7);
    max-width: 600px;
    margin: 0 auto 24px;
    line-height: 1.8;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    margin-bottom: 24px;

    .tag {
      background: var(--color-card);
      padding: 6px 16px;
      border-radius: 20px;
      font-size: 0.9rem;
      color: var(--grey-6);
    }
  }

  .hero-links {
    display: flex;
    justify-content: center;
    gap: 24px;

    .hero-link {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      border-radius: 8px;
      background: var(--color-card);
      color: var(--color-link);
      text-decoration: none;
      transition: 0.2s;

      &:hover {
        background: var(--red-1);
        color: white;
        transform: translateY(-2px);
      }
    }
  }

  .section {
    margin-bottom: 48px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 2px solid var(--color-card);
  }

  .section-title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1.4rem;
    font-weight: 600;
    color: var(--color-link);
  }

  .section-more {
    color: var(--grey-6);
    text-decoration: none;
    font-size: 0.95rem;
    transition: 0.2s;

    &:hover {
      color: var(--red-1);
    }
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .project-card {
    background: var(--color-wrap);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: 0.3s;
    display: block;

    &:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-card-hover);
    }
  }

  .project-cover {
    height: 160px;
    overflow: hidden;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: 0.3s;
    }
  }

  .project-card:hover .project-cover img {
    transform: scale(1.05);
  }

  .project-info {
    padding: 20px;
  }

  .project-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-link);
    margin-bottom: 8px;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--grey-6);
    margin-bottom: 12px;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .project-tag {
    background: var(--color-card);
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.8rem;
    color: var(--grey-5);
  }

  .notes-list {
    background: var(--color-wrap);
    border-radius: 12px;
    overflow: hidden;
  }

  .note-item {
    display: flex;
    align-items: center;
    padding: 16px 24px;
    text-decoration: none;
    border-bottom: 1px solid var(--color-card);
    transition: 0.2s;

    &:last-child {
      border-bottom: none;
    }

    &:hover {
      background: var(--color-card);
      padding-left: 32px;
    }
  }

  .note-date {
    font-size: 0.85rem;
    color: var(--grey-5);
    min-width: 100px;
    font-family: monospace;
  }

  .note-title {
    flex: 1;
    color: var(--color-link);
    font-weight: 500;
  }

  .note-arrow {
    color: var(--grey-5);
    opacity: 0;
    transition: 0.2s;
  }

  .note-item:hover .note-arrow {
    opacity: 1;
  }

  .empty-state {
    text-align: center;
    padding: 48px;
    color: var(--grey-6);
    background: var(--color-wrap);
    border-radius: 12px;
  }

  .btn {
    display: inline-block;
    margin-top: 16px;
    padding: 10px 24px;
    background: var(--red-1);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    transition: 0.2s;

    &:hover {
      background: var(--red-2);
      transform: translateY(-2px);
    }
  }
</style>
