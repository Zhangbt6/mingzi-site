---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { Icon } from "astro-icon/components";

import BaseLayout from "../../layouts/BaseLayout.astro";
import Footer from "../../components/Footer.astro";
import HeaderTitle from "../../components/partial/HeaderTitle.astro";
import { urlFor } from "../../utils/urlFor";
import { formatDate } from "../../utils/formatDate";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props;
const { Content, headings } = await render(project);

const statusLabels: Record<string, string> = {
  active: "进行中",
  completed: "已完成",
  wip: "进行中",
  archived: "已归档",
};
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  cover={project.data.cover}
>
  <HeaderTitle title={project.data.title} url={urlFor(`/projects/${project.id}`)} slot="header" />

  <section id="main" aria-label="Main content">
    <article class="project-article">
      <!-- Project Header -->
      <div class="project-header">
        <div class="project-cover">
          {
            project.data.cover ? (
              <img src={urlFor(project.data.cover)} alt={project.data.title} />
            ) : (
              <div class="cover-placeholder">
                <Icon name="fa6-solid:rocket" size={48} />
              </div>
            )
          }
        </div>
        <div class="project-meta">
          <div class="meta-item">
            <Icon name="fa6-solid:calendar" size={16} />
            <span>创建于 {project.data.date ? formatDate(project.data.date) : "未知"}</span>
          </div>
          {
            project.data.status && (
              <div class="meta-item">
                <Icon name="fa6-solid:circle-check" size={16} />
                <span>{statusLabels[project.data.status] || project.data.status}</span>
              </div>
            )
          }
          {
            project.data.links?.repo && (
              <a href={project.data.links.repo} class="meta-link" target="_blank" rel="noopener">
                <Icon name="fa6-brands:github" size={16} />
                <span>源码仓库</span>
              </a>
            )
          }
          {
            project.data.links?.demo && (
              <a href={project.data.links.demo} class="meta-link" target="_blank" rel="noopener">
                <Icon name="fa6-solid:play" size={16} />
                <span>在线演示</span>
              </a>
            )
          }
        </div>

        {
          project.data.tags && project.data.tags.length > 0 && (
            <div class="project-tags">
              {project.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )
        }
      </div>

      <!-- Project Description -->
      <div class="project-description">
        <p>{project.data.description}</p>
      </div>

      <!-- Project Content -->
      <div class="article-entry">
        <Content />
      </div>

      <!-- Back Link -->
      <div class="back-link">
        <a href={urlFor("/projects")}>
          <Icon name="fa6-solid:arrow-left" size={16} />
          返回项目列表
        </a>
      </div>
    </article>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style lang="stylus">
  .project-article {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .project-header {
    background: var(--color-wrap);
    border-radius: 12px;
    padding: 32px;
    margin-bottom: 32px;
  }

  .project-cover {
    width: 100%;
    height: 300px;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 24px;

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-card);
    color: var(--grey-5);
  }

  .project-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 20px;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--grey-6);
    font-size: 0.9rem;
  }

  .meta-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-link);
    text-decoration: none;
    font-size: 0.9rem;
    transition: 0.2s;

    &:hover {
      color: var(--red-1);
    }
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag {
    background: var(--color-card);
    padding: 6px 14px;
    border-radius: 16px;
    font-size: 0.85rem;
    color: var(--grey-6);
  }

  .project-description {
    background: var(--color-wrap);
    border-radius: 12px;
    padding: 24px;
    margin-bottom: 32px;
    border-left: 4px solid var(--red-1);

    p {
      font-size: 1.1rem;
      line-height: 1.8;
      color: var(--grey-7);
      margin: 0;
    }
  }

  .article-entry {
    background: var(--color-wrap);
    border-radius: 12px;
    padding: 40px;
    margin-bottom: 32px;
  }

  .back-link {
    text-align: center;
    padding: 24px;

    a {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      color: var(--grey-6);
      text-decoration: none;
      font-size: 0.95rem;
      transition: 0.2s;

      &:hover {
        color: var(--red-1);
      }
    }
  }
</style>
